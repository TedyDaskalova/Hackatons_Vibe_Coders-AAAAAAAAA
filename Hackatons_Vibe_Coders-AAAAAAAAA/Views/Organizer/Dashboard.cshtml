@model OrganizerDashboardViewModel
@{
    ViewData["Title"] = "Организаторско табло";
}

@if (!Model.HasProfile)
{
    <div class="alert alert-warning">
        Все още нямаш организаторски профил.
        <a asp-action="Profile" class="alert-link">Попълни профила си</a>, за да започнеш.
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="h3 mb-1">@Model.OrganizationName</h1>
            @if (!Model.Approved)
            {
                <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> Чака одобрение</span>
            }
            else
            {
                <span class="badge bg-success"><i class="bi bi-check-circle-fill"></i> Одобрен</span>
            }
        </div>
        <a asp-action="Profile" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil"></i> Редактирай профила</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <p class="text-muted mb-4">@Model.Description</p>
    }

    <div class="row g-3 mb-4">
        <div class="col-sm-6">
            <div class="card text-center border-0 bg-light">
                <div class="card-body">
                    <div class="display-6 fw-bold text-primary">@Model.EventsCount</div>
                    <div class="text-muted">Събития</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6">
            <div class="card text-center border-0 bg-light">
                <div class="card-body">
                    <div class="display-6 fw-bold text-primary">@Model.PostsCount</div>
                    <div class="text-muted">Публикации</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="card text-center border-0 bg-light">
                <div class="card-body">
                    <div class="display-6 fw-bold text-success">@Model.TicketTypesCount</div>
                    <div class="text-muted">Видове билети</div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card text-center border-0 bg-light">
                <div class="card-body">
                    <div class="display-6 fw-bold text-success">@Model.TicketsSoldCount</div>
                    <div class="text-muted">Продадени билети</div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card text-center border-0 bg-light">
                <div class="card-body">
                    <div class="display-6 fw-bold text-success">@Model.EventsWithTicketsCount</div>
                    <div class="text-muted">Събития с билети</div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2 mb-4">
        <a asp-controller="Events" asp-action="Create" class="btn btn-outline-primary"><i class="bi bi-calendar-plus"></i> Ново събитие</a>
        <a asp-controller="Posts" asp-action="Create" class="btn btn-outline-primary"><i class="bi bi-pencil-square"></i> Нова публикация</a>
        <a asp-controller="Tickets" asp-action="Validate" class="btn btn-outline-success"><i class="bi bi-qr-code-scan"></i> Валидирай билет</a>
    </div>

    @if (Model.EventTicketRows.Count > 0)
    {
        <h2 class="h5 mb-3"><i class="bi bi-ticket-perforated"></i> Билети по събития</h2>
        <div class="table-responsive mb-4">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Събитие</th>
                        <th>Начало</th>
                        <th>Статус</th>
                        <th>Продадени</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.EventTicketRows)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Events" asp-action="Details" asp-route-id="@row.EventId">@row.EventTitle</a>
                            </td>
                            <td class="small text-muted">@row.StartTime.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                @if (row.HasActiveTickets)
                                {
                                    <span class="badge bg-success">Билетите са активни</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Няма билети</span>
                                }
                            </td>
                            <td>@row.Sold</td>
                            <td class="text-end">
                                <div class="d-flex flex-wrap justify-content-end gap-1">
                                    <a asp-controller="Events" asp-action="Edit" asp-route-id="@row.EventId" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-pencil"></i> Редактирай
                                    </a>
                                    <a asp-controller="Tickets" asp-action="Manage" asp-route-id="@row.EventId" class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-ticket-perforated"></i> Управление на билети
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (Model.RecentEvents.Count > 0)
    {
        <h2 class="h5 mb-3"><i class="bi bi-calendar2-event"></i> Последни събития</h2>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3 mb-4">
            @foreach (var ev in Model.RecentEvents)
            {
                <div class="col"><partial name="_EventCard" model="ev" /></div>
            }
        </div>
    }

    @if (Model.RecentPosts.Count > 0)
    {
        <h2 class="h5 mb-3"><i class="bi bi-chat-square-text"></i> Последни публикации</h2>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
            @foreach (var post in Model.RecentPosts)
            {
                <div class="col"><partial name="_PostCard" model="post" /></div>
            }
        </div>
    }
}
