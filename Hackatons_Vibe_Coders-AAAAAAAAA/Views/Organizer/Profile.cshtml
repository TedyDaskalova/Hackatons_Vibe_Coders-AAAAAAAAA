@model OrganizerProfileViewModel
@{
    ViewData["Title"] = "Организаторски профил";
    var badgeClass = Model.Approved ? "groove-status-badge-success" : "groove-status-badge-warning";
    var badgeText = Model.Approved ? "Одобрен" : "Чака одобрение";
}

<section class="groove-app-page groove-form-shell">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-yellow">Организатор</span>
            <h1>Профил на <span>организацията</span>.</h1>
            <p>Това е публичната основа на твоята организаторска идентичност в платформата.</p>
        </div>
        <div class="groove-page-actions">
            <span class="groove-status-badge @badgeClass">@badgeText</span>
            <a asp-action="Dashboard" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> Към таблото
            </a>
        </div>
    </div>

    <div class="groove-form-panel">
        <form asp-action="Profile" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="OrganizationName" class="form-label"></label>
                <input asp-for="OrganizationName" class="form-control" />
                <span asp-validation-for="OrganizationName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="groove-form-grid">
                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label"></label>
                    <input asp-for="PhoneNumber" class="form-control" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Website" class="form-label"></label>
                    <input asp-for="Website" class="form-control" placeholder="https://..." />
                    <span asp-validation-for="Website" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="CompanyNumber" class="form-label"></label>
                <input asp-for="CompanyNumber" class="form-control" />
                <span asp-validation-for="CompanyNumber" class="text-danger small"></span>
            </div>

            <div class="groove-note mb-3">
                <strong>Важно</strong>
                Статусът на одобрение се управлява от администратор и не може да се променя оттук.
            </div>

            <div class="groove-form-actions">
                <button type="submit" class="groove-button groove-button-dark">
                    <i class="bi bi-check-lg"></i> Запази профила
                </button>
                <a asp-action="Dashboard" class="groove-button groove-button-paper">Отказ</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
