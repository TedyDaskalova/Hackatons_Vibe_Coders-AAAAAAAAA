@model EventsApp.Models.Event
@{
    ViewData["Title"] = "Изтриване на събитие";
}

<section class="groove-app-page groove-form-shell groove-form-shell-narrow">
    <div class="groove-empty-card">
        <i class="bi bi-exclamation-triangle"></i>
        <h1 class="groove-panel-title">Изтрий това <span>събитие</span>?</h1>
        <p class="groove-panel-intro">
            Наистина ли искаш да изтриеш <strong>@Model.Title</strong>? Това действие е необратимо
            и ще премахне свързаните коментари, харесвания и изображения.
        </p>

        <div class="groove-form-actions justify-content-center mt-4">
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="groove-button groove-button-dark">
                    <i class="bi bi-trash"></i> Да, изтрий
                </button>
            </form>
            <a asp-action="Details" asp-route-id="@Model.Id" class="groove-button groove-button-paper">Отказ</a>
        </div>
    </div>
</section>
