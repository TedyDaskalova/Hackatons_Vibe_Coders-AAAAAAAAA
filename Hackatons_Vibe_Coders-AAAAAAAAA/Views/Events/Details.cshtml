@model EventDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}

<section class="groove-app-page">
    <div class="groove-page-actions mb-4">
        <a asp-controller="Home" asp-action="Index" class="groove-button groove-button-paper">
            <i class="bi bi-arrow-left"></i> Назад
        </a>
        @if (Model.CanEdit)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="groove-button groove-button-paper">
                <i class="bi bi-pencil"></i> Редакция
            </a>
        }
        @if (Model.CanDelete)
        {
            <a asp-action="Delete" asp-route-id="@Model.Id" class="groove-button groove-button-paper">
                <i class="bi bi-trash"></i> Изтрий
            </a>
        }
        @if (Model.CanManageTickets)
        {
            <a asp-controller="Tickets" asp-action="Manage" asp-route-id="@Model.Id" class="groove-button groove-button-dark">
                <i class="bi bi-ticket-perforated"></i> Управление на билети
            </a>
        }
    </div>

    @if (!Model.IsApproved)
    {
        <div class="groove-alert groove-alert-warning mb-4">
            <strong>Събитието още не е одобрено.</strong>
        </div>
    }

    <div class="groove-split">
        <div class="groove-paper-card">
            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="img-fluid rounded mb-3" alt="@Model.Title" style="max-height:380px;width:100%;object-fit:cover;" />
            }
            @if (Model.ImageUrls.Count > 0)
            {
                <div class="d-flex gap-2 flex-wrap mb-3">
                    @foreach (var url in Model.ImageUrls)
                    {
                        <img src="@url" class="rounded" style="height:80px;width:80px;object-fit:cover;" alt="Изображение от събитието" />
                    }
                </div>
            }
            <span class="groove-kicker">@Model.Genre.GetDisplayName()</span>
            <h1 class="groove-panel-title">@Model.Title</h1>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="groove-panel-intro mt-3">@Model.Description</p>
            }
        </div>

        <div class="groove-info-card">
            <dl class="groove-data-list">
                <dt>Локация</dt>
                <dd>@Model.Address, @Model.City</dd>

                <dt>Начало</dt>
                <dd>@Model.StartTime.ToString("dd.MM.yyyy HH:mm")</dd>

                <dt>Край</dt>
                <dd>@Model.EndTime.ToString("dd.MM.yyyy HH:mm")</dd>

                <dt>Организатор</dt>
                <dd>@Model.OrganizerName</dd>

                <dt>Харесвания</dt>
                <dd>@Model.LikesCount</dd>
            </dl>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <hr />
                @if (Model.CurrentUserLiked)
                {
                    <form asp-action="Unlike" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button class="groove-button groove-button-dark w-100"><i class="bi bi-heart-fill"></i> Премахни харесването</button>
                    </form>
                }
                else
                {
                    <form asp-action="Like" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button class="groove-button groove-button-paper w-100"><i class="bi bi-heart"></i> Харесай</button>
                    </form>
                }
            }
        </div>
    </div>

    <section class="groove-page-section">
        <div class="groove-section-bar">
            <div>
                <span class="groove-kicker">Продажби</span>
                <h2>Налични <span>билети</span>.</h2>
            </div>
        </div>

        @if (Model.Tickets.Count == 0)
        {
            <div class="groove-empty-card">
                <i class="bi bi-ticket-perforated"></i>
                <h2 class="groove-panel-title">Все още няма <span>билети</span>.</h2>
            </div>
        }
        else
        {
            <div class="groove-ticket-grid mb-3">
                @foreach (var t in Model.Tickets)
                {
                    var ticketStatusClass = t.SoldOut ? "groove-status-badge-danger" : "groove-status-badge-success";
                    var ticketStatusText = t.SoldOut ? "Разпродаден" : $"{t.QuantityRemaining} останали";

                    <article class="groove-ticket-card">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <h3>@t.Name</h3>
                            <span class="groove-status-badge @ticketStatusClass">@ticketStatusText</span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(t.Description))
                        {
                            <p>@t.Description</p>
                        }

                        <div class="groove-ticket-footer">
                            <span class="groove-price">@t.Price.ToString("0.00") лв.</span>

                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                @if (!t.SoldOut)
                                {
                                    <form asp-controller="Tickets" asp-action="Buy" asp-route-id="@t.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="groove-button groove-button-dark">
                                            <i class="bi bi-bag-check"></i> Купи
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="groove-button groove-button-paper" disabled>Разпродаден</button>
                                }
                            }
                            else
                            {
                                <a asp-area="Identity" asp-page="/Account/Login" class="groove-button groove-button-paper">
                                    <i class="bi bi-box-arrow-in-right"></i> Влез за покупка
                                </a>
                            }
                        </div>
                    </article>
                }
            </div>
            <p class="groove-muted-copy"><i class="bi bi-info-circle"></i> Плащането е демонстрационно, а интеграцията може да бъде разширена по-късно.</p>
        }
    </section>

    <section class="groove-page-section">
        <div class="groove-section-bar">
            <div>
                <span class="groove-kicker">Разговор</span>
                <h2 id="comments">Коментари <span>(@Model.Comments.Count)</span>.</h2>
            </div>
        </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <form asp-action="AddComment" asp-route-id="@Model.Id" method="post" class="mb-4">
                @Html.AntiForgeryToken()
                <div class="input-group">
                    <input type="text" name="content" class="form-control" placeholder="Напиши коментар..." maxlength="1000" required />
                    <button class="btn btn-primary" type="submit"><i class="bi bi-send"></i> Изпрати</button>
                </div>
            </form>
        }

        @if (Model.Comments.Count == 0)
        {
            <div class="groove-empty-card">
                <i class="bi bi-chat-square-text"></i>
                <h2 class="groove-panel-title">Още няма <span>коментари</span>.</h2>
            </div>
        }
        else
        {
            <div class="groove-info-card">
                <div class="groove-list-stack">
                    @foreach (var c in Model.Comments)
                    {
                        <article class="groove-list-item">
                            <div>
                                <strong>@c.UserName</strong>
                                <p class="groove-list-meta mt-1">@c.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
                                <p>@c.Content</p>
                            </div>
                            @if (c.CanDelete)
                            {
                                <form asp-action="DeleteComment" method="post" class="ms-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="commentId" value="@c.Id" />
                                    <button class="groove-button groove-button-paper"><i class="bi bi-trash"></i> Изтрий</button>
                                </form>
                            }
                        </article>
                    }
                </div>
            </div>
        }
    </section>
</section>
