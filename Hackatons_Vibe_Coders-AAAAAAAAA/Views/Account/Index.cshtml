@using EventsApp.ViewModels.Account
@model AccountOverviewViewModel
@{
    ViewData["Title"] = "Моят профил";
    var isAdmin = Model.Role == GlobalConstants.Roles.Admin;
    var isOrganizer = Model.Role == GlobalConstants.Roles.Organizer;
    var initial = string.IsNullOrWhiteSpace(Model.UserName) ? "?" : Model.UserName[..1].ToUpperInvariant();
    var roleClass = isAdmin ? "groove-status-badge-danger"
        : isOrganizer ? "groove-status-badge-success"
        : "groove-status-badge-muted";
}

<section class="groove-app-page">
    <div class="groove-page-grid groove-page-grid-2">
        <article class="groove-paper-card">
            <div class="groove-profile-hero">
                <div class="groove-avatar">@initial</div>
                <div>
                    <span class="groove-stamp groove-stamp-red">Профил</span>
                    <h1 class="groove-panel-title">@Model.UserName</h1>
                    <p class="groove-panel-intro">@Model.Email</p>
                    <div class="groove-inline-actions mt-3">
                        <span class="groove-status-badge @roleClass">@Model.Role.ToRoleDisplay()</span>
                        <span class="groove-badge"><i class="bi bi-calendar-check"></i> От @Model.CreatedAt.ToString("MMMM yyyy")</span>
                    </div>
                </div>
            </div>

            <div class="groove-cta-row">
                <a asp-action="EditProfile" class="groove-button groove-button-dark">
                    <i class="bi bi-person-gear"></i> Редактирай профила
                </a>
                <a asp-controller="Tickets" asp-action="MyTickets" class="groove-button groove-button-paper">
                    <i class="bi bi-ticket-perforated"></i> Моите билети
                </a>
                <a asp-controller="Preferences" asp-action="Index" class="groove-button groove-button-paper">
                    <i class="bi bi-sliders"></i> Предпочитания
                </a>
            </div>
        </article>

        @if (isAdmin)
        {
            <article class="groove-highlight-card">
                <span class="groove-kicker">Роля</span>
                <h2 class="groove-panel-title">Админ <span>достъп</span>.</h2>
                <p class="groove-panel-intro">Имаш пълен контрол над платформата, ролите и съдържанието.</p>
                <div class="groove-cta-row">
                    <a asp-controller="Admin" asp-action="Index" class="groove-button groove-button-dark">
                        <i class="bi bi-shield-check"></i> Админ панел
                    </a>
                    <a asp-controller="Admin" asp-action="Users" class="groove-button groove-button-paper">
                        <i class="bi bi-people"></i> Потребители
                    </a>
                    <a asp-controller="Admin" asp-action="Organizers" class="groove-button groove-button-paper">
                        <i class="bi bi-person-badge"></i> Организатори
                    </a>
                </div>
            </article>
        }
        else if (isOrganizer)
        {
            <article class="groove-highlight-card">
                <span class="groove-kicker">Роля</span>
                <h2 class="groove-panel-title">Организаторски <span>панел</span>.</h2>
                <p class="groove-panel-intro">
                    @if (!string.IsNullOrWhiteSpace(Model.OrganizationName))
                    {
                        <text>@Model.OrganizationName</text>
                    }
                    else
                    {
                        <text>Тук управляваш своите събития, публикации и билети.</text>
                    }
                </p>
                <div class="groove-stat-grid mb-0">
                    <article class="groove-stat-card">
                        <span>Събития</span>
                        <strong>@Model.EventsCount</strong>
                    </article>
                    <article class="groove-stat-card">
                        <span>Публикации</span>
                        <strong>@Model.PostsCount</strong>
                    </article>
                </div>
                <div class="groove-cta-row">
                    <a asp-controller="Organizer" asp-action="Dashboard" class="groove-button groove-button-dark">
                        <i class="bi bi-speedometer2"></i> Организатор
                    </a>
                    <a asp-controller="Organizer" asp-action="Profile" class="groove-button groove-button-paper">
                        <i class="bi bi-pencil"></i> Организаторски профил
                    </a>
                </div>
            </article>
        }
        else if (!Model.HasApplied)
        {
            <article class="groove-highlight-card">
                <span class="groove-kicker">Следваща стъпка</span>
                <h2 class="groove-panel-title">Стани <span>организатор</span>.</h2>
                <p class="groove-panel-intro">
                    Кандидатствай, за да публикуваш събития и да продаваш билети през GrooveOn.
                </p>
                <div class="groove-cta-row">
                    <a asp-action="Apply" class="groove-button groove-button-dark">
                        <i class="bi bi-send"></i> Кандидатствай
                    </a>
                </div>
            </article>
        }
        else
        {
            <article class="groove-highlight-card">
                <span class="groove-kicker">Кандидатура</span>
                <h2 class="groove-panel-title">Статус: <span>в изчакване</span>.</h2>
                <p class="groove-panel-intro">
                    Организация: @Model.OrganizationName
                    @if (Model.ApplicationDate.HasValue)
                    {
                        <text> · подадена на @Model.ApplicationDate.Value.ToString("dd.MM.yyyy HH:mm")</text>
                    }
                </p>
                <div class="groove-cta-row">
                    <a asp-action="EditApplication" class="groove-button groove-button-paper">
                        <i class="bi bi-pencil"></i> Редактирай кандидатурата
                    </a>
                </div>
            </article>
        }
    </div>

    <section class="groove-page-section">
        <div class="groove-section-bar">
            <div>
                <span class="groove-kicker">Билети</span>
                <h2>Последни <span>покупки</span>.</h2>
            </div>
            <a asp-controller="Tickets" asp-action="MyTickets" class="groove-link">Виж всички</a>
        </div>

        <div class="groove-info-card">
            @if (Model.RecentTickets.Count == 0)
            {
                <p class="groove-panel-intro mb-0">Още нямаш закупени билети.</p>
            }
            else
            {
                <div class="groove-list-stack">
                    @foreach (var t in Model.RecentTickets)
                    {
                        var statusClass = t.IsUsed ? "groove-status-badge-muted" : "groove-status-badge-success";
                        var statusText = t.IsUsed ? "Използван" : "Валиден";

                        <article class="groove-list-item">
                            <div>
                                <h3>@t.EventTitle</h3>
                                <p>@t.TicketName</p>
                                <p class="groove-list-meta mt-2">@t.Address, @t.City · @t.StartTime.ToString("dd.MM.yyyy HH:mm")</p>
                            </div>
                            <div class="groove-list-actions">
                                <span class="groove-status-badge @statusClass">@statusText</span>
                                <a asp-controller="Tickets" asp-action="Details" asp-route-id="@t.Id" class="groove-button groove-button-paper">
                                    <i class="bi bi-eye"></i> Детайли
                                </a>
                            </div>
                        </article>
                    }
                </div>
            }
        </div>
    </section>

    <section class="groove-page-section">
        <div class="groove-section-bar">
            <div>
                <span class="groove-kicker">Навигация</span>
                <h2>Бързи <span>връзки</span>.</h2>
            </div>
        </div>

        <div class="groove-mini-grid">
            <article class="groove-mini-card">
                <h3>Начало</h3>
                <p>Разгледай нови събития и картата на сцената.</p>
                <div class="groove-cta-row">
                    <a asp-controller="Home" asp-action="Index" class="groove-link">Отвори</a>
                </div>
            </article>
            <article class="groove-mini-card">
                <h3>Поток</h3>
                <p>Виж какво публикуват организатори и посетители.</p>
                <div class="groove-cta-row">
                    <a asp-controller="Posts" asp-action="Index" class="groove-link">Отвори</a>
                </div>
            </article>
            <article class="groove-mini-card">
                <h3>Препоръчани</h3>
                <p>Подбор на събития според твоите предпочитания.</p>
                <div class="groove-cta-row">
                    <a asp-controller="Events" asp-action="Recommended" class="groove-link">Отвори</a>
                </div>
            </article>
        </div>
    </section>
</section>
