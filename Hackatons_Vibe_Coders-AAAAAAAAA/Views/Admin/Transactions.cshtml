@model AdminTransactionsViewModel
@{
    ViewData["Title"] = "Transactions";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3"><i class="bi bi-receipt"></i> Transactions</h1>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i> Admin</a>
</div>

<div class="alert alert-info">
    <strong>Total revenue (paid, demo):</strong> @Model.TotalRevenue.ToString("0.00")
</div>

@if (Model.Transactions.Count == 0)
{
    <p class="text-muted">No transactions yet.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Email</th>
                    <th>Amount</th>
                    <th>Tickets</th>
                    <th>Status</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model.Transactions)
                {
                    <tr>
                        <td>@t.UserName</td>
                        <td class="small text-muted">@t.Email</td>
                        <td>@t.TotalAmount.ToString("0.00")</td>
                        <td>@t.TicketCount</td>
                        <td>
                            @{
                                var badgeClass = t.Status switch
                                {
                                    "Paid" => "bg-success",
                                    "Pending" => "bg-warning text-dark",
                                    "Failed" => "bg-danger",
                                    "Refunded" => "bg-info text-dark",
                                    _ => "bg-secondary",
                                };
                            }
                            <span class="badge @badgeClass">@t.Status</span>
                        </td>
                        <td class="small text-muted">@t.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
