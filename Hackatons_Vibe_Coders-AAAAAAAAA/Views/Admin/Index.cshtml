@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Админ";
}

<section class="groove-app-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-yellow">Контрол</span>
            <h1>Админ <span>център</span>.</h1>
            <p>
                Оттук управляваш роли, кандидатури, събития, публикации, билети и транзакции в GrooveOn.
            </p>
        </div>
        <div class="groove-page-actions">
            <a asp-controller="Account" asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-person-circle"></i> Моят профил
            </a>
            <a asp-controller="Tickets" asp-action="Validate" class="groove-button groove-button-dark">
                <i class="bi bi-qr-code-scan"></i> Валидиране
            </a>
        </div>
    </div>

    <div class="groove-stat-grid">
        <article class="groove-stat-card">
            <span>Потребители</span>
            <strong>@Model.UsersCount</strong>
        </article>
        <article class="groove-stat-card">
            <span>Организатори</span>
            <strong>@Model.OrganizersCount</strong>
            @if (Model.PendingOrganizersCount > 0)
            {
                <div class="mt-2"><span class="groove-status-badge groove-status-badge-warning">@Model.PendingOrganizersCount чакащи</span></div>
            }
        </article>
        <article class="groove-stat-card">
            <span>Събития</span>
            <strong>@Model.EventsCount</strong>
            @if (Model.PendingEventsCount > 0)
            {
                <div class="mt-2"><span class="groove-status-badge groove-status-badge-warning">@Model.PendingEventsCount за преглед</span></div>
            }
        </article>
    </div>

    <section class="groove-page-section">
        <div class="groove-section-bar">
            <div>
                <span class="groove-kicker">Бързи действия</span>
                <h2>Всички <span>админ панели</span>.</h2>
            </div>
        </div>

        <div class="groove-mini-grid">
            <article class="groove-paper-card">
                <span class="groove-kicker">Роли</span>
                <h3 class="mt-2">Потребители</h3>
                <p>Смяна на роли и редакция на акаунти.</p>
                <div class="groove-cta-row">
                    <a asp-action="Users" class="groove-link">Отвори</a>
                </div>
            </article>
            <article class="groove-paper-card">
                <span class="groove-kicker">Кандидатури</span>
                <h3 class="mt-2">Организатори</h3>
                <p>Преглед и одобряване на нови организатори.</p>
                <div class="groove-cta-row">
                    <a asp-action="Organizers" class="groove-link">Отвори</a>
                </div>
            </article>
            <article class="groove-paper-card">
                <span class="groove-kicker">Съдържание</span>
                <h3 class="mt-2">Събития</h3>
                <p>Одобряване и управление на публикуваните събития.</p>
                <div class="groove-cta-row">
                    <a asp-action="Events" class="groove-link">Отвори</a>
                </div>
            </article>
            <article class="groove-paper-card">
                <span class="groove-kicker">Съдържание</span>
                <h3 class="mt-2">Публикации</h3>
                <p>Преглед на постовете и тяхната активност.</p>
                <div class="groove-cta-row">
                    <a asp-action="Posts" class="groove-link">Отвори</a>
                </div>
            </article>
            <article class="groove-paper-card">
                <span class="groove-kicker">Продажби</span>
                <h3 class="mt-2">Билети</h3>
                <p>Следене на продадени, използвани и активни билети.</p>
                <div class="groove-cta-row">
                    <a asp-action="Tickets" class="groove-link">Отвори</a>
                </div>
            </article>
            <article class="groove-paper-card">
                <span class="groove-kicker">Финанси</span>
                <h3 class="mt-2">Транзакции</h3>
                <p>Списък с плащания и обобщение на приходите.</p>
                <div class="groove-cta-row">
                    <a asp-action="Transactions" class="groove-link">Отвори</a>
                </div>
            </article>
        </div>
    </section>

    @if (Model.RecentPosts.Count > 0)
    {
        <section class="groove-page-section">
            <div class="groove-section-bar">
                <div>
                    <span class="groove-kicker">Активност</span>
                    <h2>Последни <span>публикации</span>.</h2>
                </div>
            </div>

            <div class="row row-cols-1 row-cols-sm-2 row-cols-xl-3 g-3">
                @foreach (var post in Model.RecentPosts)
                {
                    <div class="col"><partial name="_PostCard" model="post" /></div>
                }
            </div>
        </section>
    }
</section>
