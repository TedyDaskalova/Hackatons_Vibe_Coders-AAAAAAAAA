@model EventsApp.ViewModels.Search.SearchResultsViewModel
@{
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.Query) ? "Търсене" : $"Търсене: {Model.Query}";
}

<section class="groove-app-page groove-form-shell">
    <div class="groove-form-panel mb-4">
        <span class="groove-stamp groove-stamp-teal">Търсене</span>
        <h1 class="groove-panel-title mt-3">Умно <span>търсене</span>.</h1>
        <form asp-action="Index" method="get" class="row g-2 mt-2">
            <div class="col-12 col-md">
                <input type="text" name="q" value="@Model.Query" class="form-control form-control-lg" placeholder="Опитай: рок, джаз, София, фестивал..." autofocus />
            </div>
            <div class="col-12 col-md-auto">
                <button class="btn btn-primary btn-lg w-100" type="submit"><i class="bi bi-stars"></i> Търси</button>
            </div>
        </form>
        @if (!string.IsNullOrWhiteSpace(Model.AiHint))
        {
            <div class="groove-alert groove-alert-info mt-3 mb-0">
                <i class="bi bi-robot me-2"></i><span>@Model.AiHint</span>
            </div>
        }
    </div>

    @if (string.IsNullOrWhiteSpace(Model.Query))
    {
        <div class="groove-empty-card">
            <i class="bi bi-search"></i>
            <h2 class="groove-panel-title">Напиши <span>ключова дума</span>.</h2>
            <p class="groove-panel-intro">Можеш да търсиш по събития, градове и публикации.</p>
        </div>
    }
    else
    {
        <section class="mb-4">
            <h2 class="h5"><i class="bi bi-calendar2-event"></i> Събития (@Model.Events.Count)</h2>
            @if (Model.Events.Count == 0)
            {
                <p class="text-muted small mb-0">Няма съвпадащи събития.</p>
            }
            else
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
                    @foreach (var ev in Model.Events)
                    {
                        <div class="col"><partial name="_EventCard" model="ev" /></div>
                    }
                </div>
            }
        </section>

        <section class="mb-4">
            <h2 class="h5"><i class="bi bi-chat-square-text"></i> Публикации (@Model.Posts.Count)</h2>
            @if (Model.Posts.Count == 0)
            {
                <p class="text-muted small mb-0">Няма съвпадащи публикации.</p>
            }
            else
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
                    @foreach (var p in Model.Posts)
                    {
                        <div class="col"><partial name="_PostCard" model="p" /></div>
                    }
                </div>
            }
        </section>
    }
</section>
