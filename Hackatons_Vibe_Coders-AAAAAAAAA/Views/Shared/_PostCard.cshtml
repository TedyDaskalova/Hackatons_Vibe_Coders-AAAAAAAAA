@model EventsApp.ViewModels.Posts.PostCardViewModel
@{
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var canManage = User.IsInRole(GlobalConstants.Roles.Admin)
        || (!string.IsNullOrWhiteSpace(currentUserId) && Model.OrganizerId == currentUserId);
    var likeAction = Model.CurrentUserLiked ? "Unlike" : "Like";
    var likeTitle = Model.CurrentUserLiked ? "Премахни харесването" : "Харесай";
    var preview = Model.Content.Length > 200 ? Model.Content[..200] + "..." : Model.Content;
}

<div class="card h-100 shadow-sm post-card">
    @if (!string.IsNullOrWhiteSpace(Model.FirstMediaUrl))
    {
        if (Model.FirstMediaType == EventsApp.Models.PostMediaType.Video)
        {
            <video class="card-img-top card-img-top-fixed bg-dark" controls preload="metadata" muted>
                <source src="@Model.FirstMediaUrl" />
            </video>
        }
        else
        {
            <img src="@Model.FirstMediaUrl" class="card-img-top card-img-top-fixed" alt="Изображение към публикация" />
        }
    }
    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <strong>@Model.OrganizerName</strong>
            <small class="text-muted">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
        </div>
        @if (Model.EventId.HasValue)
        {
            <div class="mb-2">
                <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.EventId" class="small">
                    <i class="bi bi-link-45deg"></i> @Model.EventTitle
                </a>
            </div>
        }
        <p class="card-text post-body flex-grow-1">@preview</p>
        <div class="d-flex justify-content-between align-items-center gap-2 mt-auto">
            <div class="d-flex align-items-center gap-2">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var btnClass = Model.CurrentUserLiked ? "btn-danger" : "btn-outline-danger";
                    var iconClass = Model.CurrentUserLiked ? "bi-heart-fill" : "bi-heart";
                    <form asp-controller="Posts" asp-action="@likeAction" asp-route-id="@Model.Id"
                          asp-route-returnUrl="@returnUrl" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm @btnClass" type="submit" title="@likeTitle">
                            <i class="bi @iconClass"></i> @Model.LikesCount
                        </button>
                    </form>
                }
                else
                {
                    <span class="small text-muted"><i class="bi bi-heart"></i> @Model.LikesCount</span>
                }
                <a asp-controller="Posts"
                   asp-action="Details"
                   asp-route-id="@Model.Id"
                   asp-fragment="comments"
                   class="small text-muted text-decoration-none">
                    <i class="bi bi-chat"></i> @Model.CommentsCount
                </a>
            </div>
            <div class="d-flex flex-wrap justify-content-end gap-1">
                <a asp-controller="Posts" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">Отвори</a>
                @if (canManage)
                {
                    <a asp-controller="Posts" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary" title="Редактирай">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a asp-controller="Posts" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger" title="Изтрий">
                        <i class="bi bi-trash"></i>
                    </a>
                }
            </div>
        </div>
    </div>
</div>
