@model ErrorViewModel
@{
    ViewData["Title"] = "Грешка";
}

<section class="groove-app-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-red">Проблем</span>
            <h1>Нещо се обърка при <span>зареждането</span>.</h1>
            <p>
                Заявката не можа да бъде обработена успешно. Можеш да опиташ отново или да се върнеш към
                началната страница.
            </p>
        </div>
        <div class="groove-page-actions">
            <a asp-controller="Home" asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-house-door"></i> Към начало
            </a>
        </div>
    </div>

    <div class="groove-page-grid groove-page-grid-2">
        <article class="groove-highlight-card">
            <span class="groove-kicker">Статус</span>
            <h2 class="groove-panel-title">Възникна <span>грешка</span>.</h2>
            <p class="groove-panel-intro">
                Ако проблемът се повтаря, провери дали приложението е стартирано коректно и дали всички
                зависимости са налични.
            </p>
        </article>

        @if (Model.ShowRequestId)
        {
            <article class="groove-info-card">
                <span class="groove-kicker">Диагностика</span>
                <h2 class="groove-panel-title">Идентификатор на <span>заявката</span>.</h2>
                <p class="groove-panel-intro mb-2">
                    Използвай този код, ако трябва да проследиш конкретната грешка:
                </p>
                <p class="groove-note mb-0"><strong>ID:</strong> <code>@Model.RequestId</code></p>
            </article>
        }
    </div>
</section>
