@model PreferencesViewModel?
@{
    ViewData["Title"] = "Предпочитания";
}

<section class="groove-app-page groove-form-shell groove-form-shell-narrow">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-teal">Настройки</span>
            <h1>Лични <span>предпочитания</span>.</h1>
            <p>
                Използваме ги, за да подреждаме по-добре препоръчаните събития според твоя вкус.
            </p>
        </div>
        <div class="groove-page-actions">
            <a asp-action="Edit" class="groove-button groove-button-dark">
                <i class="bi bi-pencil"></i> Редактирай
            </a>
            <a asp-controller="Events" asp-action="Recommended" class="groove-button groove-button-paper">
                <i class="bi bi-stars"></i> Препоръчани
            </a>
        </div>
    </div>

    @if (Model == null)
    {
        <div class="groove-empty-card">
            <i class="bi bi-sliders"></i>
            <h2 class="groove-panel-title">Още няма <span>запазени настройки</span>.</h2>
            <p class="groove-panel-intro">Добави любим жанр, град или разстояние, за да получаваш по-точни предложения.</p>
            <div class="groove-form-actions justify-content-center">
                <a asp-action="Edit" class="groove-button groove-button-dark">
                    <i class="bi bi-plus-lg"></i> Задай предпочитания
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="groove-info-card">
            <dl class="groove-data-list">
                <dt>Предпочитан жанр</dt>
                <dd>@(Model.PreferredGenre.HasValue ? Model.PreferredGenre.Value.GetDisplayName() : "Няма зададен")</dd>

                <dt>Предпочитан град</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.PreferredCity) ? "Няма зададен" : Model.PreferredCity)</dd>

                <dt>Минимална възраст</dt>
                <dd>@(Model.MinAge.HasValue ? Model.MinAge.Value.ToString() : "Без ограничение")</dd>

                <dt>Максимално разстояние</dt>
                <dd>@(Model.MaxDistanceKm.HasValue ? $"{Model.MaxDistanceKm.Value} км" : "Без ограничение")</dd>
            </dl>
        </div>

        <form asp-action="Delete" method="post" class="mt-3">
            @Html.AntiForgeryToken()
            <button class="groove-button groove-button-paper" onclick="return confirm('Да изчистя ли всички предпочитания?')">
                <i class="bi bi-x-circle"></i> Изчисти предпочитанията
            </button>
        </form>
    }
</section>
