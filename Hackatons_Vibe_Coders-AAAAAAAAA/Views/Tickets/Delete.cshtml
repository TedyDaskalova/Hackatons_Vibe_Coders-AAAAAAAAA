@model EventsApp.Models.Ticket
@{
    ViewData["Title"] = "Изключване на билет";
    var sold = (int)(ViewBag.SoldCount ?? 0);
}

<section class="groove-app-page groove-form-shell groove-form-shell-narrow">
    <div class="groove-empty-card">
        <i class="bi bi-slash-circle"></i>
        <h1 class="groove-panel-title">Изключи този <span>тип билет</span>?</h1>
        <p class="groove-panel-intro">
            <strong>@Model.Name</strong> за <strong>@Model.Event?.Title</strong> ще спре да се продава,
            но вече купените билети ще останат валидни.
        </p>

        <dl class="groove-data-list text-start mt-4">
            <dt>Цена</dt>
            <dd>@Model.Price.ToString("0.00") лв.</dd>

            <dt>Общо</dt>
            <dd>@Model.QuantityTotal</dd>

            <dt>Остават</dt>
            <dd>@Model.QuantityRemaining</dd>

            <dt>Продадени</dt>
            <dd>@sold</dd>
        </dl>

        <div class="groove-form-actions justify-content-center mt-4">
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="groove-button groove-button-dark">
                    <i class="bi bi-slash-circle"></i> Изключи
                </button>
            </form>
            <a asp-action="Manage" asp-route-id="@Model.EventId" class="groove-button groove-button-paper">Отказ</a>
        </div>
    </div>
</section>
