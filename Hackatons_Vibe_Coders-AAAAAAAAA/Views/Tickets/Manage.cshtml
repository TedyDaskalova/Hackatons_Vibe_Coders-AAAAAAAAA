@model TicketManageViewModel
@{
    ViewData["Title"] = $"Tickets — {Model.EventTitle}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1"><i class="bi bi-ticket-perforated"></i> Tickets</h1>
        <div class="text-muted">@Model.EventTitle</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.EventId" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back to event
        </a>
        <a asp-action="Create" asp-route-id="@Model.EventId" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg"></i> Create ticket type
        </a>
    </div>
</div>

@if (Model.Tickets.Count == 0)
{
    <div class="alert alert-info">
        No ticket types yet. Click <strong>Create ticket type</strong> to enable ticket sales for this event.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Price</th>
                    <th>Total</th>
                    <th>Remaining</th>
                    <th>Sold</th>
                    <th>Used</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model.Tickets)
                {
                    <tr>
                        <td><strong>@t.Name</strong></td>
                        <td>@t.Price.ToString("0.00")</td>
                        <td>@t.QuantityTotal</td>
                        <td>@t.QuantityRemaining</td>
                        <td>@t.Sold</td>
                        <td>@t.Used</td>
                        <td>
                            @if (!t.IsActive)
                            {
                                <span class="badge bg-secondary">Disabled</span>
                            }
                            else if (t.QuantityRemaining <= 0)
                            {
                                <span class="badge bg-danger">Sold out</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Available</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@t.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-slash-circle"></i> Disable
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
