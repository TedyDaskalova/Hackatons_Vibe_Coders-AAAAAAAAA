@model EventsApp.Models.Post
@{
    ViewData["Title"] = "Изтриване на публикация";
    var preview = Model.Content.Length > 200 ? Model.Content[..200] + "..." : Model.Content;
}

<section class="groove-app-page groove-form-shell groove-form-shell-narrow">
    <div class="groove-empty-card">
        <i class="bi bi-exclamation-triangle"></i>
        <h1 class="groove-panel-title">Изтрий тази <span>публикация</span>?</h1>
        <p class="groove-panel-intro">Сигурен ли си, че искаш да премахнеш тази публикация от потока?</p>
        <blockquote class="blockquote text-muted small mt-3">"@preview"</blockquote>
        <p class="groove-muted-copy">Коментарите, харесванията и изображенията също ще бъдат изтрити.</p>

        <div class="groove-form-actions justify-content-center mt-4">
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="groove-button groove-button-dark">
                    <i class="bi bi-trash"></i> Да, изтрий
                </button>
            </form>
            <a asp-action="Details" asp-route-id="@Model.Id" class="groove-button groove-button-paper">Отказ</a>
        </div>
    </div>
</section>
