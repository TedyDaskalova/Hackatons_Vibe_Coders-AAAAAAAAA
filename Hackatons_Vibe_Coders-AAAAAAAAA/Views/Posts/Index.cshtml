@model IReadOnlyList<PostCardViewModel>
@{
    ViewData["Title"] = "Поток";
    var hasRealPosts = Model.Count > 0;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var isSignedIn = User.Identity?.IsAuthenticated == true;
    var demoPosts = new[]
    {
        new { Id = "feed-nadia-electric", Who = "Надя К.", Role = "организатор", When = "преди 2 ч.", Text = "Вратите утре отварят точно в 21:30. Носете нещо за размяна - стартираме маса за касети още от входа.", Likes = 42, Comments = new[] { new { Name = "Ивана П.", Text = "Пазя една касета специално за размяната." }, new { Name = "Марина Дневници", Text = "Такъв ъгъл трябва да има на всяко събитие." }, new { Name = "Русе Ъндърграунд", Text = "Масата за размяна е одобрена." } } },
        new { Id = "feed-field-notes", Who = "Field Notes", Role = "организатор", When = "преди 5 ч.", Text = "Прогнозата е за ясно време. Acid Picnic остава. Носете одеяло, вода и най-спокойното си следобедно настроение.", Likes = 77, Comments = new[] { new { Name = "Боби", Text = "Приготвям преносимата колона." }, new { Name = "Надя К.", Text = "Следобедното техно е ненадминато." } } },
        new { Id = "feed-marina-dawn", Who = "Марина Дневници", Role = "слушател", When = "вчера", Text = "Изгревният фолк на кея беше нереален. Прибрах се с пясък в обувките и нов любим дует.", Likes = 118, Comments = new[] { new { Name = "Old Pier Crew", Text = "Направихте сутринта ни по-хубава." }, new { Name = "Ивана П.", Text = "Втората песен ми остана в главата цял ден." }, new { Name = "Надя К.", Text = "Следващата спирка е София." } } },
        new { Id = "feed-plovdiv-echo", Who = "Plovdiv Echo Club", Role = "организатор", When = "преди 2 дни", Text = "Последните 12 билета за Concrete Resonance са онлайн. След това оставаме само с входен списък.", Likes = 64, Comments = new[] { new { Name = "Field Notes", Text = "Ще се видим в Тютюневия град." }, new { Name = "Русе Ъндърграунд", Text = "Запазете един плакат за нас." } } },
        new { Id = "feed-bobi-tape-warm", Who = "Боби и приятели", Role = "организатор", When = "преди 2 дни", Text = "Само касетофони. Някой донесе Maxell от 1986-а, която не беше свирила от години. Намалихме светлините и цялата стая задържа дъх.", Likes = 91, Comments = new[] { new { Name = "Надя К.", Text = "Това беше най-топлата стая в София." }, new { Name = "Ивана П.", Text = "Искам траклиста." }, new { Name = "Марина Дневници", Text = "Следващия път касетна вечер край морето?" } } },
    };
}

<section class="groove-feed-page">
    <div class="groove-feed-hero">
        <div>
            <span class="groove-stamp groove-stamp-teal">Потокът</span>
            <h1>Живият <span>дневник</span>.</h1>
            <p>Какво казват организаторите и слушателите точно сега. Подредено, четимо и готово за реалните публикации.</p>
        </div>
        @if (User.IsInRole(GlobalConstants.Roles.Organizer) || User.IsInRole(GlobalConstants.Roles.Admin))
        {
            <a asp-action="Create" class="groove-button groove-button-dark">
                <i class="bi bi-plus-lg"></i> Нова публикация
            </a>
        }
    </div>

    <div class="groove-feed-list">
        @foreach (var post in demoPosts)
        {
            <article id="@post.Id" class="groove-wire-card">
                <header>
                    <span class="groove-wire-card__avatar">@post.Who[0]</span>
                    <div>
                        <h2>@post.Who</h2>
                        <p>@post.Role / @post.When</p>
                    </div>
                    <i class="bi bi-rss"></i>
                </header>
                <p class="groove-wire-card__body">"@post.Text"</p>
                <footer>
                    @if (isSignedIn)
                    {
                        <button type="button" class="groove-like-toggle" data-like-toggle data-liked="false">
                            <i class="bi bi-heart"></i> <span>@post.Likes</span>
                        </button>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@(returnUrl + "#" + post.Id)" class="groove-wire-link">
                            <i class="bi bi-heart"></i> @post.Likes
                        </a>
                    }
                    <button type="button"
                            class="groove-comments-toggle"
                            data-comments-toggle
                            aria-expanded="false"
                            aria-controls="@(post.Id + "-comments")">
                        <i class="bi bi-chat"></i> @post.Comments.Length
                    </button>
                </footer>
                <div id="@(post.Id + "-comments")" class="groove-comments-panel" hidden>
                    <p class="groove-comments-title">Коментари</p>
                    @foreach (var comment in post.Comments)
                    {
                        <div class="groove-comment">
                            <strong>@comment.Name</strong>
                            <p>@comment.Text</p>
                        </div>
                    }
                </div>
            </article>
        }
    </div>

    @if (hasRealPosts)
    {
        <div class="groove-real-feed">
            <div class="groove-section-heading">
                <div>
                    <span class="groove-stamp groove-stamp-red">Реални публикации</span>
                    <h2>От <span>базата</span>.</h2>
                </div>
            </div>
            <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
                @foreach (var post in Model)
                {
                    <div class="col"><partial name="_PostCard" model="post" /></div>
                }
            </div>
        </div>
    }
</section>

@section Scripts {
    <script>
        (function () {
            document.querySelectorAll('[data-comments-toggle]').forEach(function (button) {
                button.addEventListener('click', function () {
                    var targetId = button.getAttribute('aria-controls');
                    var panel = targetId ? document.getElementById(targetId) : null;
                    if (!panel) return;

                    var isOpen = button.getAttribute('aria-expanded') === 'true';
                    document.querySelectorAll('.groove-wire-card .groove-comments-panel').forEach(function (openPanel) {
                        if (openPanel !== panel) {
                            openPanel.hidden = true;
                        }
                    });
                    document.querySelectorAll('[data-comments-toggle]').forEach(function (openButton) {
                        if (openButton !== button) {
                            openButton.setAttribute('aria-expanded', 'false');
                        }
                    });

                    button.setAttribute('aria-expanded', String(!isOpen));
                    panel.hidden = isOpen;
                });
            });

            document.querySelectorAll('[data-like-toggle]').forEach(function (button) {
                button.addEventListener('click', function () {
                    var countEl = button.querySelector('span');
                    var icon = button.querySelector('i');
                    var liked = button.getAttribute('data-liked') === 'true';
                    var count = Number(countEl ? countEl.textContent : '0');

                    button.setAttribute('data-liked', String(!liked));
                    button.classList.toggle('is-liked', !liked);
                    if (icon) {
                        icon.classList.toggle('bi-heart', liked);
                        icon.classList.toggle('bi-heart-fill', !liked);
                    }
                    if (countEl) {
                        countEl.textContent = String(count + (liked ? -1 : 1));
                    }
                });
            });

            if (window.location.hash) {
                var target = document.getElementById(window.location.hash.slice(1));
                if (target && target.classList.contains('groove-comments-panel')) {
                    document.querySelectorAll('.groove-wire-card .groove-comments-panel').forEach(function (panel) {
                        if (panel !== target) {
                            panel.hidden = true;
                        }
                    });
                    target.hidden = false;
                    var toggle = document.querySelector('[aria-controls="' + target.id + '"]');
                    if (toggle) toggle.setAttribute('aria-expanded', 'true');
                    window.setTimeout(function () {
                        target.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }, 0);
                }
            }
        })();
    </script>
}
