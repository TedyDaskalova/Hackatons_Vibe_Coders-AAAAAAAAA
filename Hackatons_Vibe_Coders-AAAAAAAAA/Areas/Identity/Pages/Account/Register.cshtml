@page
@model RegisterModel
@{
    ViewData["Title"] = "Регистрация";
}

<section class="auth-zine-page">
    <div class="auth-zine-shell auth-zine-shell-wide">
        <div class="auth-zine-copy">
            <span class="auth-zine-stamp auth-zine-stamp-red">Нов профил</span>
            <h1>Започни своя <span>дневник</span>.</h1>
            <p>Създай GrooveOn акаунт, за да запазваш вечери, да купуваш билети и да следиш любимите си организатори.</p>
        </div>

        <div class="auth-zine-card">
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="auth-zine-form">
                <div asp-validation-summary="ModelOnly" class="auth-zine-validation" role="alert"></div>

                <div class="auth-zine-grid">
                    <div class="auth-zine-field">
                        <label asp-for="Input.FirstName"></label>
                        <input asp-for="Input.FirstName" autocomplete="given-name" placeholder="Ивана" />
                        <span asp-validation-for="Input.FirstName"></span>
                    </div>
                    <div class="auth-zine-field">
                        <label asp-for="Input.LastName"></label>
                        <input asp-for="Input.LastName" autocomplete="family-name" placeholder="Петрова" />
                        <span asp-validation-for="Input.LastName"></span>
                    </div>
                </div>

                <div class="auth-zine-field">
                    <label asp-for="Input.UserName"></label>
                    <input asp-for="Input.UserName" autocomplete="username" placeholder="ivana.petrova" />
                    <span asp-validation-for="Input.UserName"></span>
                </div>

                <div class="auth-zine-field">
                    <label asp-for="Input.Email"></label>
                    <input asp-for="Input.Email" autocomplete="email" placeholder="you@grooveon.app" />
                    <span asp-validation-for="Input.Email"></span>
                </div>

                <div class="auth-zine-grid">
                    <div class="auth-zine-field">
                        <label asp-for="Input.Password"></label>
                        <input asp-for="Input.Password" autocomplete="new-password" placeholder="поне 5 символа" />
                        <span asp-validation-for="Input.Password"></span>
                    </div>
                    <div class="auth-zine-field">
                        <label asp-for="Input.ConfirmPassword"></label>
                        <input asp-for="Input.ConfirmPassword" autocomplete="new-password" placeholder="повтори паролата" />
                        <span asp-validation-for="Input.ConfirmPassword"></span>
                    </div>
                </div>

                <button id="registerSubmit" type="submit" class="auth-zine-button auth-zine-button-teal">
                    <i class="bi bi-person-plus"></i> Създай акаунт
                </button>
            </form>
        </div>

        <p class="auth-zine-alt">
            Вече имаш профил?
            <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Model.ReturnUrl">Вход</a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
